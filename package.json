{
  "name": "bizclaw",
  "private": true,
  "version": "0.1.19",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:updater-manifest": "node ./scripts/build-updater-manifest.mjs",
    "check:release-version": "node ./scripts/verify-release-version.mjs",
    "test": "pnpm test:web && pnpm test:rust",
    "test:web": "vitest run",
    "test:rust": "node ./scripts/run-rust-command.mjs cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "node ./scripts/run-rust-command.mjs tauri dev",
    "tauri:build": "node ./scripts/run-rust-command.mjs tauri build",
    "bundle:mac-dmg": "node ./scripts/build-macos-dmg.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.0.0"
  }
}
